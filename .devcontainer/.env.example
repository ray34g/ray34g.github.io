# Required by .devcontainer/scripts/initializeCommand.sh
# Host path to the ssh-agent socket used for git operations.
SSH_AGENT_SOCK=/tmp/ssh-agent.sock

# Optional: colon-separated key paths to auto-add to the agent.
# SSH_ADD_KEYS=~/.ssh/id_ed25519

# Optional: container-side socket path exported as SSH_AUTH_SOCK.
# CONTAINER_SSH_AUTH_SOCK=/ssh-agent

# Optional: semicolon-separated host entries in name,addr,user format.
# GIT_SSH_HOSTS=github.com,github.com,git

# Optional: ssh StrictHostKeyChecking value.
# SSH_STRICT_HOSTKEY=accept-new
