# Node.js / package managers
# ------------------------------------------------------------
/node_modules/
/.pnpm-store/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# ------------------------------------------------------------
# CI / tooling artifacts
# ------------------------------------------------------------
/.lighthouseci/
/.cache/
/.turbo/

# ------------------------------------------------------------
# Environment / secrets (never commit)
# ------------------------------------------------------------
.env
.env.*
!.env.example

# Private planning notes for this public repository.
/_private/

